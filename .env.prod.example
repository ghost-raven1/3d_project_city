# Public hostname for reverse proxy and certificate subject
DOMAIN=city.example.com

# Frontend API base URL injected at build time
VITE_API_URL=https://city.example.com

# CORS for REST/WebSocket backend
CORS_ORIGIN=https://city.example.com
WS_CORS_ORIGIN=https://city.example.com

# PostgreSQL
POSTGRES_DB=repo_city
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DB_SYNCHRONIZE=false
DB_ALLOW_SYNC_IN_PRODUCTION=false
PARSE_MIN_INTERVAL_MS=3500
MAX_ACTIVE_PARSE_RUNS=3
ROOM_MESSAGE_MIN_INTERVAL_MS=180

# Let's Encrypt account contact
LETSENCRYPT_EMAIL=ops@example.com

# Optional comma-separated SAN list; defaults to DOMAIN when empty
CERTBOT_DOMAINS=city.example.com,www.city.example.com

# Optional
GITHUB_TOKEN=
OLLAMA_MODEL=qwen2.5:3b-instruct
# Set true to disable local fallback and require Ollama response for narrator
NARRATOR_REQUIRE_LLM=false
# Soft timeout before narrator switches to local fallback text (milliseconds)
NARRATOR_FALLBACK_TIMEOUT_MS=5500
